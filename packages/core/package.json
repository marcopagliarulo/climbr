{
  "name": "@climbr/core",
  "version": "0.1.2",
  "description": "A TypeScript-first Node.js framework for building CLI tools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "./dist",
    "./docs",
    "./climbr.svg",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "lint": "eslint ./src",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "configstore": "^8.0.0",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcopagliarulo/climbr.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/marcopagliarulo/climbr/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/marcopagliarulo/climbr/issues"
  },
  "license": "MIT",
  "author": "Marco Pagliarulo",
  "keywords": [
    "cli",
    "framework",
    "typescript",
    "node",
    "terminal",
    "scaffolding",
    "interactive",
    "prompts"
  ],
  "sideEffects": false,
  "devDependencies": {}
}
