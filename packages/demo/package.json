{
  "name": "@climbr/demo",
  "version": "0.1.2",
  "description": "Demo CLI built with @climbr/core",
  "type": "module",
  "bin": {
    "climbr-demo": "./dist/bin/index.js",
    "demo": "./dist/bin/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/bin/index.ts",
    "lint": "eslint ./src",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@climbr/core": "^0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcopagliarulo/climbr.git",
    "directory": "packages/demo"
  },
  "homepage": "https://github.com/marcopagliarulo/climbr/tree/main/packages/demo#readme",
  "bugs": {
    "url": "https://github.com/marcopagliarulo/climbr/issues"
  },
  "license": "MIT",
  "author": "Marco Pagliarulo",
  "keywords": [
    "cli",
    "demo",
    "climbr",
    "typescript",
    "interactive",
    "prompts"
  ],
  "files": [
    "./dist",
    "README.md",
    "LICENSE"
  ]
}
